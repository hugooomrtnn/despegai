# ─── Supabase (opcional) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── AI Providers (opcional — usa parser propio si no se configura) ───────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Aviationstack — vuelos reales (RECOMENDADO, gratis) ─────────────────────
# 1. Regístrate en: https://aviationstack.com  (gratis, 500 llamadas/mes)
# 2. Copia tu API key aquí
# 3. Reinicia el servidor → se activa automáticamente
AVIATIONSTACK_API_KEY=

# ─── Amadeus (alternativa, requiere registro) ─────────────────────────────────
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# ─── Forzar modo mock aunque haya keys configuradas ──────────────────────────
# Descomenta la siguiente línea para usar siempre datos simulados:
# FLIGHT_API_PROVIDER=mock
