# ─── Supabase (opcional — la app funciona sin esto) ───────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── AI Providers (opcional — usa parser propio si no se configura) ───────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Amadeus Flight API (vuelos reales) ───────────────────────────────────────
# 1. Regístrate gratis en: https://developers.amadeus.com
# 2. Crea una app en "Self-Service APIs"
# 3. Copia el Client ID y Client Secret aquí
# 4. En test: 2000 llamadas/mes gratis. Para producción cambia BASE_URL en amadeus.ts
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# ─── Modo de vuelos ───────────────────────────────────────────────────────────
# "mock"    → datos simulados (por defecto, no necesita keys)
# "amadeus" → vuelos reales via Amadeus (requiere las keys de arriba)
# Si AMADEUS_CLIENT_ID está configurado, se activa automáticamente.
FLIGHT_API_PROVIDER=mock
