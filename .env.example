# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI Providers (optional - uses mock if not set)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Flight API Provider
# Options: mock | amadeus | kiwi | skyscanner | serpapi
FLIGHT_API_PROVIDER=mock

# Amadeus (https://developers.amadeus.com)
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# Kiwi / Tequila (https://tequila.kiwi.com)
KIWI_API_KEY=

# Skyscanner (via RapidAPI)
SKYSCANNER_API_KEY=

# SerpAPI (Google Flights scraping)
SERPAPI_API_KEY=
